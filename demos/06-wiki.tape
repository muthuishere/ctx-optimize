Output wiki.gif
Output wiki.mp4
Set FontSize 15
Set Width 1180
Set Height 640
Set Theme "Catppuccin Mocha"
Set TypingSpeed 40ms
Set Shell zsh
Set Padding 16
Hide
Type "source /private/tmp/claude-501/-Users-muthuishere-muthu-gitworkspace-nexus-workspace-brain/dc4417dd-0040-4de7-82a4-10f10843dc78/scratchpad/demos/common.sh; rm -rf /tmp/flask-vault; cd ~/ctxoptimize/flask; clear"
Enter
Sleep 1s
Show
Type "# every add regenerates a deterministic markdown wiki of the repo"
Enter
Sleep 1s
Type "ls wiki | head -8"
Enter
Sleep 3s
Type "head -24 wiki/index.md"
Enter
Sleep 5s
Type "ctx-optimize export --format obsidian --out /tmp/flask-vault"
Enter
Sleep 3s
Type "ls /tmp/flask-vault | head -6"
Enter
Sleep 4s
