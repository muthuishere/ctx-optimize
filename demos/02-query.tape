Output query.gif
Output query.mp4
Set FontSize 15
Set Width 1180
Set Height 640
Set Theme "Catppuccin Mocha"
Set TypingSpeed 40ms
Set Shell zsh
Set Padding 16
Hide
Type "source /private/tmp/claude-501/-Users-muthuishere-muthu-gitworkspace-nexus-workspace-brain/dc4417dd-0040-4de7-82a4-10f10843dc78/scratchpad/demos/common.sh; export CTX_OPTIMIZE_STORE=/private/tmp/claude-501/-Users-muthuishere-muthu-gitworkspace-nexus-workspace-brain/dc4417dd-0040-4de7-82a4-10f10843dc78/scratchpad/demos/stores; cd /private/tmp/claude-501/-Users-muthuishere-muthu-gitworkspace-nexus-workspace-brain/dc4417dd-0040-4de7-82a4-10f10843dc78/scratchpad/demos/flask; clear"
Enter
Sleep 1s
Show
Type "# ask the store — deterministic, cited, ~100ms, no LLM in the loop"
Enter
Sleep 1s
Type "ctx-optimize ask 'how are blueprints registered'"
Enter
Sleep 6s
Type "clear"
Enter
Type "# every hit carries its signature — no need to open the file"
Enter
Sleep 1s
Type "ctx-optimize card 'Blueprint.register'"
Enter
Sleep 6s
